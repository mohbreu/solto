# Coder selection: "codex" (default), "claude", or "auto"
# "auto" prefers Claude for more complex parallelizable tasks when
# ANTHROPIC_API_KEY is set, otherwise it falls back to Codex.
CODER=codex

# Optional: disable Claude Code subagents with 0/false/no
# CLAUDE_ENABLE_SUBAGENTS=1

# Optional Claude subagent mode:
# auto (default) = aggressive for complex tasks, standard otherwise
# standard       = always use the lighter built-in subagent set
# aggressive     = always use the more parallel subagent set
# off            = do not pass --agents
# CLAUDE_SUBAGENT_MODE=auto

# API keys (only the one for your selected CODER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Linear personal API key — used for comments + state updates
LINEAR_API_KEY=

# Shared GitHub webhook secret for pull_request merge callbacks
GITHUB_WEBHOOK_SECRET=

# Random token gating the /status endpoint
STATUS_TOKEN=

# Optional: override the cloudflared tunnel name (default: solto-tunnel)
# TUNNEL_NAME=solto-tunnel

# Per-project webhook signing secrets. One per project in projects.local.json,
# keyed by the UPPER_SNAKE_CASE form of the project id.
#   id "mobile-app" → MOBILE_APP_LINEAR_SECRET
#   id "my-api"     → MY_API_LINEAR_SECRET
# MOBILE_APP_LINEAR_SECRET=
